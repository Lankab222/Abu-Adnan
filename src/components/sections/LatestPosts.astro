---
import { getCollection, type CollectionEntry } from 'astro:content';
import BlogCard from '~/components/blog/BlogCard.astro';
import t from '~/data/ar.json';

interface Props {
  title?: string;
  subtitle?: string;
  viewAllText?: string;
  count?: number;
}

const arrow = '←';

const {
    title = t['blog.title'], 
    subtitle = t['blog.subtitle'],
    viewAllText = t['blog.viewAll'],
    count = 3
} = Astro.props;

// جلب المقالات وترتيبها مباشرة بدون فلاتر اللغات المعقدة
const posts = (await getCollection('blog'))
  .sort(
    (a: CollectionEntry<'blog'>, b: CollectionEntry<'blog'>) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
  ).slice(0, count);
---

<section class="py-0 bg-white/2">
    <div class="max-w-7xl mx-auto px-5">
         
         <div class="flex justify-between items-end mb-12">
            <div class="mb-0 text-center max-w-2xl mx-auto">
             <h2 class="text-4xl font-display text-yellow-600 font-bold mb-4" set:html={t["bento.title"]} />
             <p class="text-2xl text-muted-foreground">{t["bento.description"]}</p>
        </div>
            <a href={`/blog`} class="text-primary hover:text-primary/80 font-medium hidden md:block">
                {viewAllText} {arrow}
            </a>
         </div>

         <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {posts.map((post: CollectionEntry<'blog'>) => (
                <BlogCard 
                    title={post.data.title}
                    description={post.data.description}
                    pubDate={post.data.pubDate}
                    slug={`/blog/${post.id}`}  
                    heroImage={post.data.heroImage}
                    isVideo={post.data.isVideo}
                    author={post.data.author}
                    audioUrl={post.data.audioUrl}
                />
            ))}
         </div>
         
         <div class="mt-8 text-center md:hidden">
             <a href={`/blog`} class="text-primary font-medium">{viewAllText} {arrow}</a>
         </div>
    </div>
</section>