---
import Layout from '~/layouts/Layout.astro';
import PageHeader from '~/components/layout/PageHeader.astro';
import BlogCard from '~/components/blog/BlogCard.astro';
import Container from '~/components/ui/Container.astro';
import Grid from '~/components/ui/Grid.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const allAuthors = await getCollection('authors');
  const allPosts = await getCollection('blog');

  return allAuthors.map((author) => {
    // جلب مقالات هذا الكاتب لتمريرها للصفحة
    const authorPosts = allPosts.filter((post) => {
      // إصلاح السطر ليتأكد من جلب الـ ID بشكل صحيح
      const postAuthor = post.data.author || post.data.author;
      return postAuthor === author.id;
    });

    return {
      // هنا نصنع المسار: نمرر 'author' لكي يتطابق مع اسم الملف
      params: { author: author.id }, 
      props: { 
        author: author, // نمرر بيانات الكاتب بالكامل للصفحة
        posts: authorPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
      },
    };
  });
}

// استلام البيانات النظيفة والمباشرة من getStaticPaths
interface Props {
  author: CollectionEntry<'authors'>;
  posts: CollectionEntry<'blog'>[];
}

const { author, posts } = Astro.props;

// استخراج اسم ووصف الكاتب بسهولة وبدون تعقيدات
const authorName = author.data.name;
const authorDesc = author.data.description;
---

<Layout title={`${authorName} - المدونة`} description={`مقالات بواسطة ${authorName}`}>
  <Container class="pt-32">
    <a href={`/blog`} class="inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-primary transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 rotate-180"><path d="m15 18-6-6 6-6"/></svg>
        العودة للمدونة
    </a>
  </Container>

  <PageHeader 
      title={authorName}
      description={authorDesc || "مقالات الكاتب"}
  />

  <Container as="section" class="pb-24">
      {posts.length > 0 ? (
          <Grid cols={3} class="mb-16">
            {posts.map((post) => (
              <BlogCard 
                 title={post.data.title}
                 description={post.data.description}
                 pubDate={post.data.pubDate}
                 heroImage={post.data.heroImage}
                 slug={`/blog/${post.id}`}
                 isVideo={post.data.isVideo}
                 author={post.data.author}
                 audioUrl={post.data.audioUrl}
              />
            ))}
          </Grid>
      ) : (
          <div class="text-center py-20">
              <p class="text-xl text-muted-foreground">لا توجد مقالات لهذا الكاتب حالياً.</p>
          </div>
      )}
  </Container>
</Layout>